<% layout("/layouts/boilerplate") %>

<style>
  :root {
    --teal: #13b5c7;
    --teal-dark: #0d97a8;
    --navy: #1a3566;
    --navy-dark: #142a54;
    --light-bg: #f0fbfc;
  }

  /* ── Hero ── */
  .hero-section {
    margin-top: 2.5rem;
    padding: 2rem 1rem 3rem;
    text-align: center;
    background: linear-gradient(
      135deg,
      rgba(19, 181, 199, 0.05),
      rgba(26, 53, 102, 0.05)
    );
    position: relative;
    overflow: hidden;
  }
  .hero-section::before {
    content: "";
    position: absolute;
    top: -80px;
    right: -80px;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(19, 181, 199, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-section::after {
    content: "";
    position: absolute;
    bottom: -60px;
    left: -60px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(26, 53, 102, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-section h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--navy);
  }
  .hero-section h1 span {
    color: var(--teal);
  }
  .hero-section > .container > p {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #555;
    max-width: 600px;
    margin: 1rem auto 2rem;
  }
  .btn-teal {
    background-color: var(--teal);
    color: white;
    border: none;
    border-radius: 30px;
    padding: 0.75rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    transition:
      background 0.2s,
      transform 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-teal:hover {
    background-color: var(--teal-dark);
    color: white;
    transform: translateY(-2px);
  }
  .btn-outline-navy {
    background: transparent;
    color: var(--navy);
    border: 2px solid var(--navy);
    border-radius: 30px;
    padding: 0.7rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    transition:
      background 0.2s,
      color 0.2s,
      transform 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-outline-navy:hover {
    background: var(--navy);
    color: white;
    transform: translateY(-2px);
  }
  .hero-btns {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 2px solid #f0f0f0;
  }
  .hero-stat {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--light-bg);
    border-radius: 2rem;
    padding: 0.55rem 1.25rem;
  }
  .hero-stat i {
    font-size: 1.1rem;
    color: var(--teal);
  }
  .hero-stat p {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--navy);
  }

  /* ── Features ── */
  .features-section {
    padding: 5rem 1rem;
    background: white;
  }
  .section-title {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-title h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--navy);
  }
  .section-title p {
    color: #666;
    max-width: 550px;
    margin: 0.5rem auto 0;
  }
  .feature-card {
    border: none;
    border-radius: 1.25rem;
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    transition:
      transform 0.25s,
      box-shadow 0.25s;
    height: 100%;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 30px rgba(19, 181, 199, 0.18);
  }
  .feature-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    font-size: 1.75rem;
    background: var(--light-bg);
    color: var(--teal);
  }
  .feature-card h5 {
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.6rem;
  }
  .feature-card p {
    color: #666;
    font-size: 0.95rem;
    margin: 0;
  }

  /* ── How It Works ── */
  .how-section {
    padding: 5rem 1rem;
    background: var(--light-bg);
  }
  .step-number {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--navy));
    color: white;
    font-weight: 800;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .step-card {
    text-align: center;
    padding: 1.5rem 1rem;
  }
  .step-card h5 {
    font-weight: 700;
    color: var(--navy);
  }
  .step-card p {
    color: #666;
    font-size: 0.95rem;
  }

  /* ── CTA Banner ── */
  .cta-section {
    background: white;
    padding: 5rem 1rem;
    text-align: center;
    border-top: 2px solid #f0f0f0;
  }
  .cta-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--navy);
  }
  .cta-section p {
    color: #555;
    max-width: 500px;
    margin: 0 auto 2rem;
  }
</style>

<!-- ── HERO ── -->
<section class="hero-section">
  <div class="container">
    <h1>Find Your Perfect Stay,<br /><span>Anywhere in the World</span></h1>
    <p>
      StayFinder connects travelers with unique homes, apartments, and
      properties. Browse thousands of listings or list your own space today.
    </p>
    <div class="hero-btns">
      <a href="/listings" class="btn-teal">
        <i class="fa-solid fa-magnifying-glass me-2"></i>Explore Listings
      </a>
      <a
        href="<%= currentUser ? '/listings' : '/signup' %>"
        class="btn-outline-navy"
      >
        <i class="fa-solid fa-user-plus me-2"></i>Get Started Free
      </a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <i class="fa-solid fa-circle-check"></i>
        <p>Free to Browse</p>
      </div>
      <div class="hero-stat">
        <i class="fa-solid fa-bolt"></i>
        <p>Instant Booking</p>
      </div>
      <div class="hero-stat">
        <i class="fa-solid fa-user-shield"></i>
        <p>Verified Hosts</p>
      </div>
      <div class="hero-stat">
        <i class="fa-solid fa-lock"></i>
        <p>Secure & Safe</p>
      </div>
      <div class="hero-stat">
        <i class="fa-solid fa-headset"></i>
        <p>24/7 Support</p>
      </div>
    </div>
  </div>
</section>

<!-- ── FEATURES ── -->
<section class="features-section">
  <div class="container">
    <div class="section-title">
      <h2>Why Choose StayFinder?</h2>
      <p>
        Everything you need to find or list a property — simple, fast, and
        trusted.
      </p>
    </div>
    <div class="row g-4">
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-house-circle-check"></i>
          </div>
          <h5>Verified Listings</h5>
          <p>
            Every property is reviewed to ensure accuracy, quality, and safety
            before going live.
          </p>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-magnifying-glass-location"></i>
          </div>
          <h5>Smart Search</h5>
          <p>
            Filter by location, price, and property type to find exactly what
            you're looking for.
          </p>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <h5>Secure Booking</h5>
          <p>
            Your bookings and personal information are protected with
            industry-leading security.
          </p>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-headset"></i></div>
          <h5>24/7 Support</h5>
          <p>
            Our support team is always available to help hosts and guests with
            any issue.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ── -->
<section class="how-section">
  <div class="container">
    <div class="section-title">
      <h2>How It Works</h2>
      <p>Get started in just three simple steps.</p>
    </div>
    <div class="row g-4">
      <div class="col-12 col-md-4">
        <div class="step-card">
          <div class="step-number">1</div>
          <h5>Create an Account</h5>
          <p>
            Sign up for free in seconds. No credit card required to get started
            browsing properties.
          </p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="step-card">
          <div class="step-number">2</div>
          <h5>Search & Discover</h5>
          <p>
            Browse thousands of unique properties by location, price range, or
            property type.
          </p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="step-card">
          <div class="step-number">3</div>
          <h5>Book & Enjoy</h5>
          <p>
            Confirm your stay instantly and enjoy a hassle-free experience from
            check-in to check-out.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── GET STARTED CTA ── -->
<section class="cta-section">
  <div class="container">
    <h2>Ready to Find Your Perfect Stay?</h2>
    <p>
      Join thousands of travelers and hosts on StayFinder. It's free to get
      started.
    </p>
    <div class="hero-btns">
      <a href="/listings" class="btn-outline-navy">
        <i class="fa-solid fa-binoculars me-2"></i>Browse Listings
      </a>
      <a href="/listings/new" class="btn-teal">
        <i class="fa-solid fa-plus me-2"></i>List Your Property
      </a>
    </div>
  </div>
</section>
